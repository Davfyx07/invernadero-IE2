# Copia este archivo como .env y llena los valores reales
# NUNCA subas .env a Git (ya esta en .gitignore)

# ─── Base de datos ─────────────────────────────
DB_USER=postgres
DB_PASSWORD=pon_tu_password_aqui

# ─── JWT ───────────────────────────────────────
JWT_SECRET=genera_un_secret_largo_y_aleatorio

# ─── Google OAuth ─────────────────────────────
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret

# ─── SMTP Gmail ───────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_correo@gmail.com
MAIL_PASSWORD=tu_app_password

# ─── Admin inicial ────────────────────────────
ADMIN_EMAIL=admin@cenit.app
ADMIN_PASSWORD=una_password_segura

# ─── URL del frontend ─────────────────────────
APP_FRONTEND_URL=https://cenit.vercel.app
